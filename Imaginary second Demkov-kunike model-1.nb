Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"t1_", ",", "t2_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Chi]", "+", "\[Mu]", "+", "1"}], ")"}], " ", 
     RowBox[{"Log", "[", 
      RowBox[{"z", "[", "t1", "]"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Zeta]", "+", "\[Nu]", "+", "1"}], ")"}], " ", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "-", 
       RowBox[{"z", "[", "t1", "]"}]}], "]"}]}], "-", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Chi]", "+", "\[Mu]", "+", "1", "-", "\[Gamma]"}], ")"}], 
     RowBox[{"Log", "[", 
      RowBox[{"z", "[", "t2", "]"}], "]"}]}], "-", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
      "\[Zeta]", "+", "\[Nu]", "+", "\[Gamma]", "-", "\[Rho]", "-", 
       "\[Omega]"}], ")"}], 
     RowBox[{"Log", "[", 
      RowBox[{"1", "-", 
       RowBox[{"z", "[", "t2", "]"}]}], "]"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"U22", "[", 
     RowBox[{"t1_", ",", "t2_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Gamma]"}], ")"}]]}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{
          RowBox[{"Gamma", "[", "\[Rho]", "]"}], " ", 
          RowBox[{"Gamma", "[", "\[Omega]", "]"}]}], 
         RowBox[{
          RowBox[{"Gamma", "[", 
           RowBox[{"\[Rho]", "+", "\[Omega]", "-", "\[Gamma]", "+", "1"}], 
           "]"}], " ", 
          RowBox[{"Gamma", "[", " ", 
           RowBox[{"\[Gamma]", "-", "1"}], "]"}]}]], " ", 
        RowBox[{"F", "[", 
         RowBox[{"t1", ",", "t2"}], "]"}]}], "-", 
       RowBox[{
        FractionBox[
         RowBox[{
          RowBox[{"Gamma", "[", "\[Rho]", "]"}], " ", 
          RowBox[{"Gamma", "[", "\[Omega]", "]"}], " ", 
          RowBox[{"Gamma", "[", 
           RowBox[{"1", "-", "\[Gamma]"}], "]"}]}], 
         RowBox[{
          RowBox[{"Gamma", "[", 
           RowBox[{"\[Rho]", "-", "\[Gamma]", "+", "1"}], "]"}], " ", 
          RowBox[{"Gamma", "[", 
           RowBox[{"\[Omega]", "-", "\[Gamma]", "+", "1"}], "]"}], " ", 
          RowBox[{"Gamma", "[", 
           RowBox[{"\[Gamma]", "-", "1"}], "]"}]}]], " ", 
        RowBox[{"S", "[", 
         RowBox[{"t1", ",", "t2"}], "]"}]}], "-", 
       RowBox[{"s", "[", "t1", "]"}]}], ")"}], "   ", 
     RowBox[{"Exp", "[", 
      RowBox[{"u", "[", 
       RowBox[{"t1", ",", "t2"}], "]"}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Probability2", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"Re", "[", 
      RowBox[{"U22", "[", 
       RowBox[{"t", ",", "t0"}], "]"}], "]"}], "^", "2"}], "+", 
    RowBox[{
     RowBox[{"Im", "[", 
      RowBox[{"U22", "[", 
